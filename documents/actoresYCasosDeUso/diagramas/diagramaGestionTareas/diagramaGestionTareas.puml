@startuml DiagramaGestionTareas
left to right direction

actor "Administrador" as Admin
actor "Miembro" as Miem

package "Gestión de Tareas" {
    usecase "crearTarea()" as UC1
    usecase "editarTarea()" as UC2
    usecase "eliminarTarea()" as UC3
    usecase "marcarCompletada()" as UC4
    usecase "relacionarTareas()" as UC5
    usecase "establecerHorario()" as UC6
    usecase "definirLocalizacion()" as UC7
    usecase "abrirTareas()" as UC8
    usecase "validarConflicto()" as UC9
}

Admin --> UC1
Admin --> UC3
Admin --> UC4
Admin --> UC8
Admin -left-> UC2

Miem --> UC8
Miem --> UC4

' Relaciones de extensión
UC2 <.. UC5 : <<extend>>
UC2 <.. UC4 : <<extend>>
UC2 <.. UC9 : <<extend>> 
UC1 <.. UC6 : <<extend>>
UC1 <.. UC7 : <<extend>>

@enduml