@startuml DiagramaGestionTareas
left to right direction

actor "Administrador" as Admin
actor "Miembro" as Miem

package "Gestión de Tareas" {
    ' Casos de Uso Principales
    usecase "crearTarea()" as UC1
    usecase "editarTarea()" as UC2
    usecase "eliminarTarea()" as UC3
    usecase "marcarCompletada()" as UC4
    usecase "abrirTareas()" as UC8

    ' Casos de Uso de Detalle (Extensiones)
    usecase "relacionarTareas()" as UC5
    usecase "establecerHorario()" as UC6
    usecase "definirLocalizacion()" as UC7
    usecase "validarConflicto()" as UC9
    usecase "configurarRecordatorio()" as UC10
    usecase "asignarTareaAUsuario()" as UC11
}

' Relaciones directas para el Administrador
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC8

' Relaciones directas para el Miembro
Miem --> UC4
Miem --> UC8

' Relaciones de extensión (UC2 concentra ahora toda la configuración avanzada)
UC2 <.. UC4 : <<extend>>
UC2 <.. UC5 : <<extend>>
UC2 <.. UC6 : <<extend>>
UC2 <.. UC7 : <<extend>>
UC2 <.. UC9 : <<extend>>
UC2 <.. UC10 : <<extend>>
UC2 <.. UC11 : <<extend>>

@enduml