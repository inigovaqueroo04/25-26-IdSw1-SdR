@startuml
hide empty description

' Estilos visuales
skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor Green
}
skinparam note {
    BackgroundColor LightYellow
    BorderColor Gray
}

' 1. Entrada
state ORGANIZACION_GRUPOS_ABIERTO

' 2. Estado compuesto principal: crearGrupo()
state "crearGrupo()" as MainBlock {
    
    [*] --> Paso1
    note on link
        **Administrador** solicita crear un nuevo grupo
    end note

    state Paso1 as " "
    
    Paso1 --> Paso2
    note on link
        **Sistema** solicita datos del grupo
        (ID, Nombre, etc.)
    end note

    state Paso2 as " "

    Paso2 --> [*]
    note on link
        **Administrador** introduce los datos y confirma
        **Sistema** valida y crea el grupo
    end note
}

' Conexión de entrada
ORGANIZACION_GRUPOS_ABIERTO -down-> MainBlock

' 3. Salida
state GRUPO_ABIERTO
MainBlock -down-> GRUPO_ABIERTO

' 4. Operaciones disponibles tras crear el grupo (Salidas desde GRUPO_ABIERTO según Contexto)

' Bucle de operaciones sobre el grupo (invitar, asignar, editar)
state operacionesGrupo as "invitarUsuario()\nasignarTareaAUsuario()\neditarGrupo()"
GRUPO_ABIERTO -down-> operacionesGrupo
operacionesGrupo -up-> GRUPO_ABIERTO

' Navegación hacia tareas
state CONSULTA_TAREAS_ABIERTO
state irTareas as "visualizarTareasGrupo()"
GRUPO_ABIERTO -down-> irTareas
irTareas -down-> CONSULTA_TAREAS_ABIERTO

' Navegación de vuelta a la lista (abrirGrupos)
state volverLista as "abrirGrupos()"
GRUPO_ABIERTO -right-> volverLista
volverLista -up-> ORGANIZACION_GRUPOS_ABIERTO

@enduml