@startuml editarInvitacion
skinparam monochrome false
skinparam shadow false
top to bottom direction

skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor #009900
    StartColor Black
    EndColor Black
}

skinparam note {
    BackgroundColor #FFFFE0
    BorderColor #B0B060
    FontName Arial
}

state "INVITACIONES_ABIERTO" as EntradaLista
state "INVITACION_ABIERTO" as EntradaDetalle

state "editarInvitacion()" as MainBlock {
    
    state " " as Paso1
    state " " as Paso2
    state " " as Paso3

    [*] --> Paso1
    note on link
        **Miembro** solicita editar invitación
    end note

    Paso1 --> Paso2
    note on link
        **Sistema** visualiza datos de la invitación
        • **Sistema** permite introducir cambios en el estado (Aceptar/Rechazar)
        • **Sistema** permite solicitar guardar cambios
        • **Sistema** permite solicitar cancelar edición
    end note

    Paso2 --> Paso3
    note on link
        **Miembro** introduce los cambios y solicita guardar
    end note

    Paso3 --> [*]
    note on link
        **Sistema** visualiza la invitación actualizada
    end note
}

state "INVITACION_ABIERTO" as FinInvitacion
state "INVITACIONES_ABIERTO" as FinLista

EntradaLista --> MainBlock
EntradaDetalle --> MainBlock

MainBlock -[#009900]-> FinInvitacion

MainBlock -[#red]down-> FinInvitacion
note on link
    cancelar edición (desde detalle)
end note

MainBlock -[#red]down-> FinLista
note on link
    cancelar edición (desde lista)
end note

@enduml