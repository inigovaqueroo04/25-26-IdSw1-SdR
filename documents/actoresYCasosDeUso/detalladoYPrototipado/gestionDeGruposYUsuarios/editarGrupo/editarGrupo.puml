@startuml
hide empty description

' Estilos visuales
skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor Green
}
skinparam note {
    BackgroundColor LightYellow
    BorderColor Gray
}

' 1. Estados de Entrada
state GRUPOS_ABIERTO
state GRUPO_ABIERTO

' 2. Estado compuesto principal: editarGrupo()
state "editarGrupo()" as MainBlock {
    
    ' Inicio
    [*] --> Paso1
    note on link
        **Administrador solicita** editar grupo
    end note

    state Paso1 as " "

    ' Acción del Sistema 1: Mostrar lo que hay
    Paso1 --> Paso2
    note on link
        **Sistema visualiza** datos actuales del grupo
    end note

    state Paso2 as " "

    ' Acción del Sistema 2: Habilitar edición (Separado)
    Paso2 --> Paso3
    note on link
        **Sistema permite introducir** cambios
    end note

    state Paso3 as " "

    ' Acción del Actor: Escribir
    Paso3 --> Paso4
    note on link
        **Administrador introduce** cambios
    end note

    state Paso4 as " "

    ' Acción del Sistema 3: Confirmación final
    Paso4 --> [*]
    note on link
        **Sistema presenta** grupo modificado
    end note
}

' 3. Conexiones de Entrada
GRUPOS_ABIERTO -down-> MainBlock
GRUPO_ABIERTO -down-> MainBlock

' 4. Salida
MainBlock -down-> GRUPO_ABIERTO

@enduml