@startuml
' Configuración visual
skinparam monochrome false
skinparam shadow false
top to bottom direction

skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor #009900
    StartColor Black
    EndColor Black
}

skinparam note {
    BackgroundColor #FFFFE0
    BorderColor #B0B060
    FontName Arial
}

' Estados externos de entrada
state GRUPOS_ABIERTO
state GRUPO_ABIERTO
state TAREAS_ABIERTO

' Estado compuesto principal
state "editarGrupo()" as EditarGrupoContainer {
    
    state " " as EstadoPreVisualizacion
    state " " as EstadoDecision
    
    [*] --> EstadoPreVisualizacion
    note on link
        **Administrador** solicita editar grupo
    end note

    EstadoPreVisualizacion --> EstadoDecision
    note on link
        **Sistema** visualiza datos actuales del grupo
        **Sistema** permite solicitar:
        * modificar campos
        * guardar grupo
        * cancelar edición
    end note

    ' Bucle
    EstadoDecision -[#green]up-> EstadoPreVisualizacion
    note on link
        **Administrador** solicita modificar campos
    end note

    ' Salidas internas
    EstadoDecision -[#green]down-> [*]
    note on link
        **Administrador** solicita guardar y salir
    end note

    EstadoDecision -[#red]down-> [*]
    note on link
        **Administrador** solicita cancelar edición
    end note
}

' Estado final externo
state "GRUPO_ABIERTO" as GrupoAbiertoFinal

' --- TRANSICIONES EXTERNAS ---

GRUPOS_ABIERTO --> EditarGrupoContainer
GRUPO_ABIERTO --> EditarGrupoContainer
TAREAS_ABIERTO --> EditarGrupoContainer

' --- SALIDAS HACIA GRUPO_ABIERTO ---

' 1. Salida de Éxito (Verde)
' TRUCO: Añadimos comillas con espacios vacíos para forzar la separación visual
EditarGrupoContainer -[#green]-> GrupoAbiertoFinal : "              "

' 2. Salida de Cancelación (Rojo)
EditarGrupoContainer -[#red]-> GrupoAbiertoFinal
note on link
    cancelar edición
end note

@enduml