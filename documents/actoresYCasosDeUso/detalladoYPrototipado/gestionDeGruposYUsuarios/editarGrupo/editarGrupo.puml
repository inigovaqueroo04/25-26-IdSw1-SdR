@startuml
hide empty description

' Estilos visuales
skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor Green
}
skinparam note {
    BackgroundColor LightYellow
    BorderColor Gray
}

' 1. Estados de Entrada (Arriba)
' Usamos alias para duplicar visualmente el estado GRUPO_ABIERTO arriba sin romper la lógica
state GRUPOS_ABIERTO
state "GRUPO_ABIERTO" as GRUPO_ABIERTO_IN
state TAREAS_ABIERTO

' 2. Estado de Salida (Abajo)
state "GRUPO_ABIERTO" as GRUPO_ABIERTO_OUT

' 3. Estado compuesto principal: editarGrupo()
state "editarGrupo()" as MainBlock {
    
    ' Inicio
    [*] --> Paso1
    note on link
        **Administrador solicita** editar grupo
    end note

    state Paso1 as " "

    ' Sistema muestra datos actuales
    Paso1 --> Paso2
    note on link
        **Sistema visualiza** datos actuales del grupo
    end note

    state Paso2 as " "

    ' Sistema habilita edición (Separado)
    Paso2 --> Paso3
    note on link
        **Sistema permite introducir** cambios
    end note

    state Paso3 as " "

    ' Actor introduce cambios
    Paso3 --> Paso4
    note on link
        **Administrador introduce** cambios
    end note

    state Paso4 as " "

    ' Sistema confirma y termina
    Paso4 --> [*]
    note on link
        **Sistema visualiza** grupo modificado
    end note
}

' 4. Conexiones
' Todas las entradas bajan al bloque principal
GRUPOS_ABIERTO -down-> MainBlock
GRUPO_ABIERTO_IN -down-> MainBlock
TAREAS_ABIERTO -down-> MainBlock

' Salida final
MainBlock -down-> GRUPO_ABIERTO_OUT

@enduml