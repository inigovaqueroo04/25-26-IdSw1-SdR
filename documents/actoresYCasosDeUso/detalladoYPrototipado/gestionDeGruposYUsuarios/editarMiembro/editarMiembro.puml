@startuml editarMiembro
skinparam monochrome false
skinparam shadow false
top to bottom direction

skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor #009900
    StartColor Black
    EndColor Black
}

skinparam note {
    BackgroundColor #FFFFE0
    BorderColor #B0B060
    FontName Arial
}

state "GRUPO_ABIERTO" as EntradaGrupo
state "MIEMBRO_ABIERTO" as EntradaMiembro

state "editarMiembro()" as MainBlock {
    
    state " " as Paso1
    state " " as Paso2
    state " " as Paso3

    [*] --> Paso1
    note on link
        **Administrador** solicita editar miembro
    end note

    Paso1 --> Paso2
    note on link
        **Sistema** visualiza datos actuales del miembro
        • **Sistema** permite introducir cambios en el rol o permisos
        • **Sistema** permite solicitar guardar cambios
        • **Sistema** permite solicitar cancelar edición
    end note

    Paso2 --> Paso3
    note on link
        **Administrador** introduce los cambios y solicita guardar
    end note

    Paso3 --> [*]
    note on link
        **Sistema** visualiza los datos actualizados del miembro
    end note
}

state "MIEMBRO_ABIERTO" as FinMiembro
state "GRUPO_ABIERTO" as FinGrupo

EntradaGrupo --> MainBlock
EntradaMiembro --> MainBlock

MainBlock -[#009900]-> FinMiembro

MainBlock -[#red]down-> FinMiembro
note on link
    cancelar edición (desde miembro)
end note

MainBlock -[#red]down-> FinGrupo
note on link
    cancelar edición (desde grupo)
end note

@enduml