@startuml completarGestion
top to bottom direction
skinparam classAttributeIconSize 0
skinparam ArrowColor Green

state "SISTEMA_DISPONIBLE" as SISTEMA_DISPONIBLE
state "GESTION_TAREAS_ABIERTO" as GESTION_TAREAS_ABIERTO
state "PLANIFICACION_ABIERTO" as PLANIFICACION_ABIERTO
state "ORGANIZACION_GRUPOS_ABIERTO" as ORGANIZACION_GRUPOS_ABIERTO
state "GRUPO_ABIERTO" as GRUPO_ABIERTO
state "CONSULTA_TAREAS_ABIERTO" as CONSULTA_TAREAS_ABIERTO
state "CREACION_TAREA_ABIERTO" as CREACION_TAREA_ABIERTO

state "completarGestion()" as completarGestion {
  [*] --> paso

  note right #FFF2CC
  Usuario solicita completar gestion
  end note

  paso --> fin

  note right #FFF2CC
  Sistema finaliza la gestion actual
  • Cierra el contexto de trabajo abierto
  • Si hay cambios pendientes, permite:
    - guardar
    - descartar
    - cancelar salida
  end note

  fin --> [*]
}

GESTION_TAREAS_ABIERTO --> completarGestion : completarGestion()
PLANIFICACION_ABIERTO --> completarGestion : completarGestion()
ORGANIZACION_GRUPOS_ABIERTO --> completarGestion : completarGestion()
GRUPO_ABIERTO --> completarGestion : completarGestion()
CONSULTA_TAREAS_ABIERTO --> completarGestion : completarGestion()
CREACION_TAREA_ABIERTO --> completarGestion : completarGestion()

completarGestion --> SISTEMA_DISPONIBLE : (finalizar)
completarGestion --> GESTION_TAREAS_ABIERTO : (cancelar salida)
completarGestion --> PLANIFICACION_ABIERTO : (cancelar salida)
completarGestion --> ORGANIZACION_GRUPOS_ABIERTO : (cancelar salida)
completarGestion --> GRUPO_ABIERTO : (cancelar salida)
completarGestion --> CONSULTA_TAREAS_ABIERTO : (cancelar salida)
completarGestion --> CREACION_TAREA_ABIERTO : (cancelar salida)

@enduml
