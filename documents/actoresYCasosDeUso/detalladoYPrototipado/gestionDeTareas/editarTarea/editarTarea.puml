@startuml
skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor #008000
}
skinparam note {
    BackgroundColor #FEFECE
    BorderColor #D7B75F
}

state TAREA_ABIERTO

state "editarTarea()" as editarTarea {
    state " " as Inicio <<start>>
    state " " as Edicion
    state " " as Guardado
    state " " as Fin <<end>>
    
    Inicio --> Edicion
    note on link
        <b>Usuario</b> solicita introducir modificaciones
    end note
    
    Edicion --> Guardado
    note on link
        <b>Sistema</b> permite introducir datos
    end note

    Guardado --> Fin
    note on link
        <b>Usuario</b> introduce datos
        <b>Sistema</b> muestra tarea actualizada
    end note
}

TAREA_ABIERTO --> editarTarea
editarTarea --> TAREA_ABIERTO
@enduml