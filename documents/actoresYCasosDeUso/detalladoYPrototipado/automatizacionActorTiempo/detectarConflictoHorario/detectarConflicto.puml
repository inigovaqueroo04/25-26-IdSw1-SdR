@startuml
hide empty description

skinparam state {
    BackgroundColor White
    BorderColor Black
    ArrowColor Green
}
skinparam note {
    BackgroundColor LightYellow
    BorderColor Gray
}

state AUTOMATIZACION_ACTIVA

state "detectarConflicto()" as MainBlock {
    
    ' Definición explicita de estados para evitar errores de compilación
    state " " as Paso1
    state " " as Paso2
    
    [*] --> Paso1
    note on link
        ' Verbo tabla: El actor SOLICITA
        **Actor solicita** comprobación de horarios
    end note

    Paso1 --> Paso2
    note on link
        ' Verbo tabla: El sistema PERMITE SOLICITAR 
        ' (Es la forma de decir que el sistema procesa la solicitud)
        **Sistema permite solicitar** la verificación
    end note

    Paso2 --> [*]
    note on link
        ' Verbo tabla: El sistema PRESENTA / MUESTRA
        **Sistema presenta** el conflicto encontrado
    end note
}

state CONFLICTO_ABIERTO

' Conexiones externas
AUTOMATIZACION_ACTIVA -down-> MainBlock
MainBlock -down-> CONFLICTO_ABIERTO

@enduml